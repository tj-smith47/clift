#!/usr/bin/env bash
# clift standard-mode wrapper for %%CLI_NAME%%
# Generated by setup:cli. Do not edit by hand — re-run setup to regenerate.

set -euo pipefail

export FRAMEWORK_DIR="%%FRAMEWORK_DIR%%"
export CLI_DIR="%%CLI_DIR%%"
CLI_NAME="%%CLI_NAME%%"
CLI_VERSION="%%CLI_VERSION%%"
export CLI_NAME CLI_VERSION

if ! command -v jq &>/dev/null; then
  echo "error: jq is required but not installed. See https://jqlang.github.io/jq/download/" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$FRAMEWORK_DIR/lib/flags/errors.sh"

# shellcheck source=/dev/null
source "$FRAMEWORK_DIR/lib/cache.sh"
clift_ensure_cache "$CLI_DIR" "$FRAMEWORK_DIR"
export CLIFT_CACHE_VERIFIED=1

# Special top-level cases that short-circuit the dispatch walk.
if (( $# == 0 )); then
  exec task --taskfile "$CLI_DIR/Taskfile.yaml"
fi

case "$1" in
  --help|-h)
    exec task --taskfile "$CLI_DIR/Taskfile.yaml" _help:list
    ;;
  --version|-V)
    echo "$CLI_NAME version $CLI_VERSION"
    exit 0
    ;;
esac

# Load known task names and root command names from the precompiled cache.
# Single jq call extracts both: (1) all task names recursively (filtering out
# framework-internal underscore-prefixed tasks), and (2) root-level command
# names for did-you-mean suggestions.
# `task --list-all --json --nested` has two sources of tasks: .tasks[] and
# .namespaces.<ns>.tasks[] (recursive). The recursive-descent query flattens
# any nesting depth. We filter out framework-internal tasks (underscore
# prefixed at any segment).
TASKS_JSON="$CLI_DIR/.clift/tasks.json"
{
  IFS= read -r -d '' known_tasks || true
  IFS= read -r -d '' root_cmds || true
} < <(jq -j '
  ([.. | .tasks? // empty | .[] | .name | select(test("^_|:_") | not)]
    | join("\n")) + "\u0000" +
  ([.tasks[]?.name // empty, (.namespaces // {} | keys)[]]
    | map(select(startswith("_") | not))
    | unique | join(" ")) + "\u0000"
' "$TASKS_JSON")

# Build O(1) lookup tables for exact-match and prefix-match
declare -A _known_exact=()
declare -A _known_prefix=()
while IFS= read -r _t; do
  [[ -z "$_t" ]] && continue
  _known_exact["$_t"]=1
  # Register all prefixes of this task name
  _pfx="$_t"
  while [[ "$_pfx" == *:* ]]; do
    _pfx="${_pfx%:*}"
    _known_prefix["$_pfx"]=1
  done
done <<< "$known_tasks"

# root_cmds is space-separated and used by did-you-mean error suggestion
# function. It contains root task names (.tasks[].name) plus namespace keys
# (top-level includes). Using `to_entries[] | .key` against BOTH task objects
# and the namespaces map — the plan's original query — would leak field names
# like "name"/"task"/"desc" from the task objects into the candidate list, so
# we select by shape instead.

# Is $1 exactly a known task, or a strict prefix (colon-extended) of one?
# Used to decide whether the longest-prefix walk can consume one more token.
_is_task_prefix() {
  local c="$1"
  [[ -n "${_known_exact[$c]+x}" ]] || [[ -n "${_known_prefix[$c]+x}" ]]
}

# Join arguments with ':' without spawning a subshell.
# Sets _JOINED instead of printing, so the caller reads $_JOINED.
_join_colon() {
  local IFS=':'
  _JOINED="${*}"
}

# Longest-prefix walk: consume non-flag tokens while each extended path is
# still a prefix of some known task. Stop at the first flag or at the first
# token that would make the path non-matching.
# Note: "${arr[@]+"${arr[@]}"}" is used throughout this file (and router.sh)
# instead of plain "${arr[@]}" to avoid "unbound variable" errors on bash < 4.4
# when the array is empty and set -u is active.
path=()
i=1
while (( i <= $# )); do
  tok="${!i}"
  if [[ "$tok" == -* ]]; then
    break
  fi
  candidate_path=("${path[@]+"${path[@]}"}" "$tok")
  _join_colon "${candidate_path[@]}"
  joined="$_JOINED"
  if _is_task_prefix "$joined"; then
    path=("${candidate_path[@]}")
    i=$((i+1))
  else
    break
  fi
done

_join_colon "${path[@]+"${path[@]}"}"
matched_task="$_JOINED"

# Empty path handling: either the first token was a flag (flags-before-command
# error) or it was an unrecognized command (did-you-mean suggestion).
if (( ${#path[@]} == 0 )); then
  first="${1:-}"
  if [[ "$first" == -* ]]; then
    clift_err_flag_before_command "$CLI_NAME" || exit 1
  else
    clift_err_unknown_command "$first" "$root_cmds" || exit 1
  fi
fi

# Collect remaining tokens (from position i onward).
remaining=()
for (( j=i; j<=$#; j++ )); do
  remaining+=("${!j}")
done

# Ambiguity check: if any non-flag token in the remaining args would extend
# the matched path to a known task, the user likely meant that subcommand but
# interrupted the command with a flag. Emit a "subcommand must come before
# flags" error with a reordered suggestion.
for r in "${remaining[@]+"${remaining[@]}"}"; do
  [[ "$r" == -* ]] && continue
  would_be="${matched_task}:${r}"
  if _is_task_prefix "$would_be"; then
    display_path="$(echo "$matched_task" | tr ':' ' ')"
    flag_tail=()
    for t in "${remaining[@]}"; do
      [[ "$t" == "$r" ]] && continue
      flag_tail+=("$t")
    done
    clift_err_subcmd_before_flags "$CLI_NAME" "$display_path" "$r" "${flag_tail[@]}" || exit 1
  fi
done

# Dispatch via indexed env vars. Task can't forward positional args through
# aliased tasks, so we pass argv out-of-band. The router/parser reassembles
# the argv from CLIFT_ARG_COUNT + CLIFT_ARG_1..N.
export CLIFT_ARG_COUNT="${#remaining[@]}"
k=0
for arg in "${remaining[@]+"${remaining[@]}"}"; do
  k=$((k+1))
  export "CLIFT_ARG_$k=$arg"
done

exec task --taskfile "$CLI_DIR/Taskfile.yaml" "$matched_task"
