#!/usr/bin/env bash
# clift standard-mode wrapper for %%CLI_NAME%%
# Generated by setup:cli. Do not edit by hand — re-run setup to regenerate.

set -euo pipefail

export FRAMEWORK_DIR="%%FRAMEWORK_DIR%%"
export CLI_DIR="%%CLI_DIR%%"
CLI_NAME="%%CLI_NAME%%"
CLI_VERSION="%%CLI_VERSION%%"
export CLI_NAME CLI_VERSION

if ! command -v jq &>/dev/null; then
  echo "error: jq is required but not installed. See https://jqlang.github.io/jq/download/" >&2
  exit 1
fi

# shellcheck source=/dev/null
source "$FRAMEWORK_DIR/lib/flags/errors.sh"

# --no-cache scan: translate the flag to CLIFT_CACHE=rebuild and strip it
# from argv so the router's parser doesn't see it twice (it IS a global
# flag, but the wrapper owns it — cache work runs before the parser).
# Only the exact bare form `--no-cache` is consumed; `--no-cache=foo` is
# bool-invalid and falls through to the parser's error path. Stops at `--`
# per bash convention: tokens after the terminator are literal.
_nc_new_args=()
_nc_saw_terminator=0
for _nc_a in "$@"; do
  if (( _nc_saw_terminator == 0 )); then
    if [[ "$_nc_a" == "--" ]]; then
      _nc_saw_terminator=1
    elif [[ "$_nc_a" == "--no-cache" ]]; then
      export CLIFT_CACHE=rebuild
      continue
    fi
  fi
  _nc_new_args+=("$_nc_a")
done
if (( ${#_nc_new_args[@]} != $# )); then
  set -- "${_nc_new_args[@]+"${_nc_new_args[@]}"}"
fi
unset _nc_new_args _nc_a _nc_saw_terminator

# shellcheck source=/dev/null
source "$FRAMEWORK_DIR/lib/cache.sh"
clift_ensure_cache "$CLI_DIR" "$FRAMEWORK_DIR"
# Under bypass mode the cache is intentionally not verified — downstream
# consumers (router) must run their own bypass check. Setting VERIFIED=1
# would defeat the `skip cache entirely` contract.
if [[ "${CLIFT_CACHE:-}" != "bypass" ]]; then
  export CLIFT_CACHE_VERIFIED=1
fi

# Special top-level cases that short-circuit the dispatch walk.
if (( $# == 0 )); then
  exec task --taskfile "$CLI_DIR/Taskfile.yaml"
fi

case "$1" in
  --help|-h)
    exec task --taskfile "$CLI_DIR/Taskfile.yaml" _help:list
    ;;
  --version|-V)
    # shellcheck source=/dev/null
    source "${FRAMEWORK_DIR}/lib/runtime/overrides.sh"
    clift_call_override version_print clift_default_version_print "$CLI_NAME" "$CLI_VERSION" "$CLI_DIR"
    exit 0
    ;;
esac

# Load known task names and root command names from the precompiled cache.
# Single jq call extracts both: (1) all task names recursively (filtering out
# framework-internal underscore-prefixed tasks), and (2) root-level command
# names for did-you-mean suggestions.
# `task --list-all --json --nested` has two sources of tasks: .tasks[] and
# .namespaces.<ns>.tasks[] (recursive). The recursive-descent query flattens
# any nesting depth. We filter out framework-internal tasks (underscore
# prefixed at any segment).
TASKS_JSON="$CLI_DIR/.clift/tasks.json"
INDEX_JSON="$CLI_DIR/.clift/index.json"
# Graceful degrade under CLIFT_CACHE=bypass: if tasks.json is absent, fall
# through with empty dispatch state so go-task handles unknown-task errors.
# Under default/rebuild modes a missing tasks.json is a hard failure — the
# user's cache is broken and they need a clean slate.
if [[ ! -f "$TASKS_JSON" ]]; then
  if [[ "${CLIFT_CACHE:-}" == "bypass" ]]; then
    # Bypass + no cache: hand off raw argv directly to go-task. The wrapper's
    # dispatch walk needs the cache to resolve longest-prefix task paths, and
    # without it any argv would dead-end at the "unknown command" error path.
    # Short-circuiting here lets go-task emit its own resolution errors for
    # unknown tasks — matching the docs' promise that bypass gracefully
    # degrades to raw go-task dispatch.
    export CLIFT_ARG_COUNT="$#"
    _k=0
    for _a in "$@"; do
      _k=$((_k+1))
      export "CLIFT_ARG_$_k=$_a"
    done
    unset _k _a
    exec task --taskfile "$CLI_DIR/Taskfile.yaml" "$@"
  else
    echo "error: task cache missing: $TASKS_JSON" >&2
    echo "  try: rm -rf '$CLI_DIR/.clift' and re-run" >&2
    exit 1
  fi
else
  # One jq call extracts everything the wrapper's dispatch walk needs:
  #   1. known_tasks   — every task name (for prefix lookup)
  #   2. root_cmds     — root command names + namespaces (for did-you-mean)
  #   3. persistent_tsv — one row per persistent flag: name<\x01>short<\x01>type
  # jq reads both tasks.json (positional input) and index.json (--slurpfile) in
  # a single invocation so there's no extra fork on the wrapper hot path.
  # index.json may be absent on a stale/partially-built cache — jq's null
  # arithmetic handles that via `// []` defaults.
  {
    IFS= read -r -d '' known_tasks || true
    IFS= read -r -d '' root_cmds || true
    IFS= read -r -d '' persistent_tsv || true
  } < <(jq -j --slurpfile idx_wrap <(
      if [[ -f "$INDEX_JSON" ]]; then cat "$INDEX_JSON"; else echo '{"persistent_flags":[]}'; fi
    ) '
    ([.. | .tasks? // empty | .[] | .name | select(test("^_|:_") | not)]
      | join("\n")) + "\u0000" +
    ([.tasks[]?.name // empty, (.namespaces // {} | keys)[]]
      | map(select(startswith("_") | not))
      | unique | join(" ")) + "\u0000" +
    (($idx_wrap[0].persistent_flags // [])
      | map([.name, (.short // ""), .type] | join("\u0001"))
      | join("\n")) + "\u0000"
  ' "$TASKS_JSON")
fi

# Build persistent-flag lookup tables. Empty list is the common case and costs
# essentially nothing (one empty read).
declare -A _persist_type _persist_name_by_short
_persist_any=0
while IFS=$'\x01' read -r _pname _pshort _ptype; do
  [[ -z "$_pname" ]] && continue
  _persist_type["$_pname"]="$_ptype"
  [[ -n "$_pshort" ]] && _persist_name_by_short["$_pshort"]="$_pname"
  _persist_any=1
done <<< "$persistent_tsv"

# Transform a long name to its CLIFT_FLAG_* env var name.
_clift_persist_var() {
  local upper="${1^^}"
  _PERSIST_VAR="CLIFT_FLAG_${upper//-/_}"
}

# Track which persistent flag names were bound by the wrapper's early-bind
# pass. CLIFT_PERSIST_BOUND is consumed by the router's parser to suppress
# default-application for these names — a wrapper-bound value is a user
# value and must outrank a default.
_CLIFT_PERSIST_BOUND=""

# Export a parsed persistent flag value. Handles bool/list/int/string.
# Args: name type value
_clift_persist_set() {
  local _name="$1" _type="$2" _value="$3" _var
  _clift_persist_var "$_name"; _var="$_PERSIST_VAR"
  case " $_CLIFT_PERSIST_BOUND " in
    *" $_name "*) ;;
    *) _CLIFT_PERSIST_BOUND="${_CLIFT_PERSIST_BOUND:+${_CLIFT_PERSIST_BOUND} }$_name" ;;
  esac
  case "$_type" in
    bool)
      export "${_var}=${_value}"
      ;;
    list)
      # List flags accumulate across repeated occurrences. Each value may
      # itself be comma-separated (matching parser.sh semantics).
      local _cv="${_var}_COUNT" _cur _items _it
      _cur="${!_cv:-0}"
      IFS=',' read -ra _items <<< "$_value"
      for _it in "${_items[@]}"; do
        _cur=$((_cur+1))
        export "${_var}_${_cur}=${_it}"
      done
      export "${_cv}=${_cur}"
      ;;
    *)
      export "${_var}=${_value}"
      ;;
  esac
}

# Build O(1) lookup tables for exact-match and prefix-match
declare -A _known_exact=()
declare -A _known_prefix=()
while IFS= read -r _t; do
  [[ -z "$_t" ]] && continue
  _known_exact["$_t"]=1
  # Register all prefixes of this task name
  _pfx="$_t"
  while [[ "$_pfx" == *:* ]]; do
    _pfx="${_pfx%:*}"
    _known_prefix["$_pfx"]=1
  done
done <<< "$known_tasks"

# root_cmds is space-separated and used by did-you-mean error suggestion
# function. It contains root task names (.tasks[].name) plus namespace keys
# (top-level includes). Using `to_entries[] | .key` against BOTH task objects
# and the namespaces map — the plan's original query — would leak field names
# like "name"/"task"/"desc" from the task objects into the candidate list, so
# we select by shape instead.

# Is $1 exactly a known task, or a strict prefix (colon-extended) of one?
# Used to decide whether the longest-prefix walk can consume one more token.
_is_task_prefix() {
  local c="$1"
  [[ -n "${_known_exact[$c]+x}" ]] || [[ -n "${_known_prefix[$c]+x}" ]]
}

# Join arguments with ':' without spawning a subshell.
# Sets _JOINED instead of printing, so the caller reads $_JOINED.
_join_colon() {
  local IFS=':'
  _JOINED="${*}"
}

# Longest-prefix walk: consume non-flag tokens while each extended path is
# still a prefix of some known task. Stop at the first flag or at the first
# token that would make the path non-matching.
# Note: "${arr[@]+"${arr[@]}"}" is used throughout this file (and router.sh)
# instead of plain "${arr[@]}" to avoid "unbound variable" errors on bash < 4.4
# when the array is empty and set -u is active.
path=()
i=1
# When we see a bare "--" anywhere during the walk, it terminates wrapper flag
# scanning per bash convention: all remaining tokens are literal and pass
# through verbatim to the router. If no command token has been matched yet
# the empty-path branch below applies (either the root task runs, or we emit
# the flag-before-command / unknown-command error).
_terminator_seen=0
while (( i <= $# )); do
  tok="${!i}"
  if [[ "$tok" == "--" ]]; then
    # End-of-options terminator: stop scanning entirely. The terminator
    # itself is kept in `remaining` so the router's parser sees it and
    # treats subsequent tokens as positionals (parser.sh handles `--`).
    _terminator_seen=1
    break
  fi
  if [[ "$tok" == -* ]]; then
    # Early-bind persistent flags that appear BEFORE the command token.
    # Strip them from argv so they don't reach the router's parser twice.
    # Only long/short forms declared in persistent_flags are consumed here —
    # unknown flags stop the walk and reach the router/parser untouched
    # (which will emit the normal "flags-before-command" / "unknown flag"
    # error downstream).
    if (( _persist_any == 1 )); then
      _consumed_persist=0
      if [[ "$tok" == --* ]]; then
        _lname="${tok#--}"
        _linline=""
        _lhas_inline=false
        if [[ "$_lname" == *=* ]]; then
          _linline="${_lname#*=}"
          _lname="${_lname%%=*}"
          _lhas_inline=true
        fi
        if [[ -n "${_persist_type[$_lname]+x}" ]]; then
          _ltype="${_persist_type[$_lname]}"
          if [[ "$_ltype" == "bool" ]]; then
            # Bool persistent flags reject inline values; match parser.sh.
            if [[ "$_lhas_inline" == true ]]; then
              clift_err_bool_with_value "$_lname" "$_linline" || exit 1
            fi
            _clift_persist_set "$_lname" "$_ltype" "true"
            i=$((i+1))
          else
            if [[ "$_lhas_inline" == true ]]; then
              _clift_persist_set "$_lname" "$_ltype" "$_linline"
              i=$((i+1))
            else
              if (( i + 1 > $# )); then
                echo "error: flag $tok requires a value" >&2
                exit 1
              fi
              _next=$((i+1))
              _clift_persist_set "$_lname" "$_ltype" "${!_next}"
              i=$((i+2))
            fi
          fi
          _consumed_persist=1
        fi
      elif [[ "$tok" == -?* && "$tok" != --* ]]; then
        _rest="${tok#-}"
        # -x=value form
        if [[ "$_rest" == ?=* ]]; then
          _sh="${_rest:0:1}"
          _sval="${_rest#*=}"
          _sname="${_persist_name_by_short[$_sh]:-}"
          if [[ -n "$_sname" ]]; then
            _stype="${_persist_type[$_sname]}"
            # Bool persistent flags reject inline values; match parser.sh.
            if [[ "$_stype" == "bool" ]]; then
              clift_err_bool_with_value "$_sname" "$_sval" || exit 1
            fi
            _clift_persist_set "$_sname" "$_stype" "$_sval"
            i=$((i+1))
            _consumed_persist=1
          fi
        elif (( ${#_rest} == 1 )); then
          _sh="$_rest"
          _sname="${_persist_name_by_short[$_sh]:-}"
          if [[ -n "$_sname" ]]; then
            _stype="${_persist_type[$_sname]}"
            if [[ "$_stype" == "bool" ]]; then
              _clift_persist_set "$_sname" "$_stype" "true"
              i=$((i+1))
            else
              if (( i + 1 > $# )); then
                echo "error: flag $tok requires a value" >&2
                exit 1
              fi
              _next=$((i+1))
              _clift_persist_set "$_sname" "$_stype" "${!_next}"
              i=$((i+2))
            fi
            _consumed_persist=1
          fi
        fi
      fi
      if (( _consumed_persist == 1 )); then
        continue
      fi
    fi
    break
  fi
  candidate_path=("${path[@]+"${path[@]}"}" "$tok")
  _join_colon "${candidate_path[@]}"
  joined="$_JOINED"
  if _is_task_prefix "$joined"; then
    path=("${candidate_path[@]}")
    i=$((i+1))
  else
    break
  fi
done

_join_colon "${path[@]+"${path[@]}"}"
matched_task="$_JOINED"

# Empty path handling: either the first token was a flag (flags-before-command
# error) or it was an unrecognized command (did-you-mean suggestion).
# Exception 1: if only persistent flags were provided (i.e., every arg was
# consumed by the early-bind pass), fall through to the root task so the
# persistent flag values are still observable by any root-level logic. The
# exported CLIFT_FLAG_* env vars carry them forward.
# Exception 2: if the `--` terminator was seen, all tokens after it are
# literal. Dispatch to the root task; those tokens ride along as positionals
# so user scripts/help can observe them without the wrapper interpreting them.
if (( ${#path[@]} == 0 )); then
  if (( i > $# )); then
    # All argv consumed by persistent-flag early-bind. Proceed to root task.
    [[ -n "$_CLIFT_PERSIST_BOUND" ]] && export CLIFT_PERSIST_BOUND="$_CLIFT_PERSIST_BOUND"
    exec task --taskfile "$CLI_DIR/Taskfile.yaml"
  fi
  if (( _terminator_seen == 1 )); then
    # Post-terminator tokens pass through to the root task as literal argv.
    remaining=()
    for (( j=i; j<=$#; j++ )); do
      remaining+=("${!j}")
    done
    [[ -n "$_CLIFT_PERSIST_BOUND" ]] && export CLIFT_PERSIST_BOUND="$_CLIFT_PERSIST_BOUND"
    export CLIFT_ARG_COUNT="${#remaining[@]}"
    k=0
    for arg in "${remaining[@]+"${remaining[@]}"}"; do
      k=$((k+1))
      export "CLIFT_ARG_$k=$arg"
    done
    exec task --taskfile "$CLI_DIR/Taskfile.yaml"
  fi
  first="${1:-}"
  if [[ "$first" == -* ]]; then
    clift_err_flag_before_command "$CLI_NAME" || exit 1
  else
    clift_err_unknown_command "$first" "$root_cmds" || exit 1
  fi
fi

# Collect remaining tokens (from position i onward).
remaining=()
for (( j=i; j<=$#; j++ )); do
  remaining+=("${!j}")
done

# Ambiguity check: if any non-flag token in the remaining args would extend
# the matched path to a known task, the user likely meant that subcommand but
# interrupted the command with a flag. Emit a "subcommand must come before
# flags" error with a reordered suggestion.
for r in "${remaining[@]+"${remaining[@]}"}"; do
  [[ "$r" == -* ]] && continue
  would_be="${matched_task}:${r}"
  if _is_task_prefix "$would_be"; then
    display_path="$(echo "$matched_task" | tr ':' ' ')"
    flag_tail=()
    for t in "${remaining[@]}"; do
      [[ "$t" == "$r" ]] && continue
      flag_tail+=("$t")
    done
    clift_err_subcmd_before_flags "$CLI_NAME" "$display_path" "$r" "${flag_tail[@]}" || exit 1
  fi
done

# Intercept global flags BEFORE dispatch. This ensures they work for ALL
# commands — both routed (user cmds) and non-routed (framework cmds like
# config, completion, update) that bypass router.sh.
for _ha in "${remaining[@]+"${remaining[@]}"}"; do
  case "$_ha" in
    --help|-h)
      exec bash "$FRAMEWORK_DIR/lib/help/detail.sh" "$matched_task" "$CLI_DIR/Taskfile.yaml"
      ;;
    --verbose|-v) export VERBOSE=true ;;
    --quiet|-q)   export QUIET=true ;;
    --no-color)   export NO_COLOR=1 ;;
  esac
done

# Advertise persistent flags the wrapper bound pre-command so the router's
# parser doesn't clobber them with defaults. Skip the export when nothing was
# bound — keeps the environment tidy for scripts that introspect it.
[[ -n "$_CLIFT_PERSIST_BOUND" ]] && export CLIFT_PERSIST_BOUND="$_CLIFT_PERSIST_BOUND"

# Dispatch via indexed env vars. Task can't forward positional args through
# aliased tasks, so we pass argv out-of-band. The router/parser reassembles
# the argv from CLIFT_ARG_COUNT + CLIFT_ARG_1..N.
export CLIFT_ARG_COUNT="${#remaining[@]}"
k=0
for arg in "${remaining[@]+"${remaining[@]}"}"; do
  k=$((k+1))
  export "CLIFT_ARG_$k=$arg"
done

exec task --taskfile "$CLI_DIR/Taskfile.yaml" "$matched_task"
