version: '3'

silent: true
output:
  group:
    begin: ''
    end: ''
set: [errexit, pipefail]
dotenv: ['.env']

vars:
  FLAGS:
    - {name: help,     short: h, type: bool, desc: "Show help"}
    - {name: verbose,  short: v, type: bool, desc: "Verbose output"}
    - {name: quiet,    short: q, type: bool, desc: "Suppress info/success output"}
    - {name: no-color,           type: bool, desc: "Disable color output"}
    - {name: version,            type: bool, desc: "Show version"}

  # CLI-wide (persistent) flags. Merged into every command's flag table and
  # accepted either before or after the command token (e.g. `mycli --profile=x cmd`
  # or `mycli cmd --profile=x`). Read from scripts as CLIFT_FLAG_<NAME>.
  # Uncomment and tailor to enable.
  # PERSISTENT_FLAGS:
  #   - {name: profile, short: p, type: string, default: "default", desc: "Profile name"}

includes:
  # Framework libs (underscore prefix = hidden from help)
  _help:
    taskfile: '{{.FRAMEWORK_DIR}}/lib/help'
  _log:
    taskfile: '{{.FRAMEWORK_DIR}}/lib/log'

  # Framework tools (visible)
  new:
    taskfile: '{{.FRAMEWORK_DIR}}/lib/scaffold'
  import:
    taskfile: '{{.FRAMEWORK_DIR}}/lib/import'
  config:
    taskfile: '{{.FRAMEWORK_DIR}}/lib/config'
  update:
    taskfile: '{{.FRAMEWORK_DIR}}/lib/update'
  completion:
    taskfile: '{{.FRAMEWORK_DIR}}/lib/completion'

  # User commands (added by scaffolder)

tasks:
  default:
    desc: "Show help"
    cmd:
      task: _help:list

  version:
    desc: "Print version"
    cmd: echo "%%CLI_NAME%% version %%CLI_VERSION%%"
